# =============================================================
#  서논술형 자동 채점 앱 — 환경변수 예시
#  Vercel > Project > Settings > Environment Variables 에 그대로 입력하세요.
#  (로컬 개발 시에는 이 파일을 .env.local 로 복사해 값을 채우세요.)
# =============================================================

# --- Firebase 클라이언트 SDK (브라우저 노출 OK: NEXT_PUBLIC_ 접두사) ---
# Firebase 콘솔 > 프로젝트 설정 > 일반 > "내 앱" > SDK 설정에서 복사
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin SDK (서버 전용, 절대 클라이언트 노출 금지) ---
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > "새 비공개 키 생성"으로 받은 JSON에서 복사
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# private_key는 줄바꿈을 \n 으로 이스케이프해서 한 줄로 붙여넣고 양끝을 큰따옴표로 감싸세요.
# 예: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Google Gemini API (서버 전용, OCR·머리글 추출·채점에 사용) ---
# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=
# 기본 모델 (선택, 미지정 시 gemini-3.5-flash). 회차별로 화면에서 따로 선택할 수도 있음.
# OCR·머리글 추출에 쓰이며, 채점은 회차 설정의 "채점 모델"이 우선한다.
GEMINI_MODEL=gemini-3.5-flash

# =============================================================
#  2차 확장 (이메일 발송) — 1차 MVP에서는 비워두어도 됩니다.
# =============================================================
RESEND_API_KEY=
# 발신 이메일 주소 (Resend에서 검증된 도메인/주소)
EMAIL_FROM=
