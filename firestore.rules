rules_version = '2';

// 데이터 격리 원칙(1번): 교사 본인 인스턴스에서 본인 데이터만 접근.
// 1차 뼈대용 기본 규칙 — 로그인한 사용자만 읽기/쓰기 허용.
// (학생 온라인 입력 경로는 2차에서 접속코드 기반 제한 규칙으로 보강)
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
