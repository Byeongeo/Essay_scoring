rules_version = '2';

// 서논술형 채점 앱 보안 규칙.
// 이 앱의 데이터(subjects 트리)에만 적용되도록 범위를 좁혔다.
// → 기존 프로젝트를 공유해서 쓰는 경우, 이 블록만 기존 규칙에 "병합"하면
//   다른 컬렉션(예: 학생 리포트/설문 데이터)은 영향받지 않는다.
// 데이터 격리 원칙(1번): 로그인한 교사만 접근.
service cloud.firestore {
  match /databases/{database}/documents {
    match /subjects/{subjectId} {
      allow read, write: if request.auth != null;
      // 하위 assessments / rubric / submissions / stats 전부 포함
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
